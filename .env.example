# Variables de entorno requeridas por el sistema multi-agente
#
# INSTRUCCIONES:
#   1. Copia este fichero a .env  (nunca subas .env al repo)
#   2. Rellena los valores reales
#   3. Carga las variables antes de arrancar tu LLM:
#      - Bash/Zsh: source .env  o añádelas a ~/.bashrc / ~/.zshrc
#      - PowerShell: ver instrucciones al final del fichero
#      - Windows GUI: Panel de control > Variables de entorno del sistema

# ── GitHub MCP ──────────────────────────────────────────────────────────────
# Token personal de GitHub para el MCP github (issues, PRs, búsqueda de repos)
# Crear en: https://github.com/settings/tokens
# Permisos mínimos: repo (read), issues (read/write), pull_requests (read/write)
GITHUB_PERSONAL_ACCESS_TOKEN=ghp_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── Anthropic API ────────────────────────────────────────────────────────────
# Requerido para OpenCode y pipelines automatizados con el SDK de Anthropic
# Crear en: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── MCPs opcionales ──────────────────────────────────────────────────────────
# Descomenta y rellena según los MCPs que uses en tu proyecto

# Notion (para el MCP docs, si el proyecto usa Notion)
# NOTION_API_TOKEN=secret_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Slack (si usas un MCP de Slack para notificaciones)
# SLACK_BOT_TOKEN=xoxb-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── Cómo cargar en PowerShell ────────────────────────────────────────────────
# Ejecuta esto una vez por sesión, o añádelo a tu $PROFILE:
#
#   Get-Content .env | ForEach-Object {
#     if ($_ -match '^([^#][^=]*)=(.*)$') {
#       [System.Environment]::SetEnvironmentVariable($Matches[1].Trim(), $Matches[2].Trim(), 'Process')
#     }
#   }
